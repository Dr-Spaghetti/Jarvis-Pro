# Octogent + Skills — environment variables
#
# Copy this file to `.env` in your project root and fill in the keys you need.
# Octogent loads `.env` at startup and forwards every variable to the agents it
# spawns, so a single keystore powers all tentacles and bundled skills.
#
# Real environment variables always win — anything already set in your shell is
# never overwritten by this file.
#
# Check which keys are missing at any time with:
#   octogent skills status
#   octogent skills doctor

# --- Jarvis voice AI (instant answers + real-time web search) ---
#
# Jarvis answers in this order: Claude Haiku (if ANTHROPIC_API_KEY) → OpenAI
# web-search model (if OPENAI_API_KEY, below) → local Ollama (offline fallback).
# Either cloud key gives fast, accurate answers WITH live web data; Ollama alone
# is slow and can't look anything up.
#
# Preferred when set — Claude Haiku. Get a key at console.anthropic.com → API keys.
ANTHROPIC_API_KEY=
#
# OpenAI also powers live answers using the same key as voice STT/TTS (see
# OPENAI_API_KEY above). Optionally override the web-search model:
# OPENAI_CHAT_MODEL=gpt-4o-mini-search-preview

# Optional: enables real-time web search (weather, news, prices, scores, etc.)
# Pick one — Brave is simpler, Tavily is optimised for LLM tool use.
#
# Brave Search API (free tier: 2,000 queries/month):
#   https://api.search.brave.com/ → Dashboard → API keys
BRAVE_SEARCH_API_KEY=
#
# Tavily (alternative, also has a free tier):
#   https://tavily.com/
# TAVILY_API_KEY=

# video-performance-analyzer — Google Gemini (transcript + analysis)
# Also requires: pip install google-genai --break-system-packages
GEMINI_API_KEY=

# x-scanner — xAI Grok API (x_search)
XAI_API_KEY=

# twitter-reader — Jina.ai reader API
JINA_API_KEY=

# obsidian-second-brain — file-based fallback when not using the live MCP server.
# Point this at your Obsidian vault root (the live MCP route needs no key here).
OBSIDIAN_VAULT_PATH=

# --- Gmail OAuth (email-assistant, daily-brief, review-repair-outreach) ---
#
# One-time setup (takes ~2 minutes):
#   1. Go to console.cloud.google.com → APIs & Services → Credentials
#   2. Create an OAuth 2.0 Client ID (type: Desktop app or Web application)
#   3. Under Authorized redirect URIs add: http://127.0.0.1:8787/api/gmail/callback
#   4. Paste the Client ID and Client Secret below, then restart Octogent
#   5. Open Octogent Settings → Gmail → click "Connect Gmail" — sign in once
#      and the refresh token is written here automatically.
#
# Required to show the Connect Gmail button:
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Written automatically after clicking Connect Gmail in Settings (do not edit):
# GMAIL_REFRESH_TOKEN=
# GMAIL_ACCESS_TOKEN=
# GMAIL_USER_EMAIL=

# --- Remote access (phone / outside your home network) ---
#
# When set, EVERY API and WebSocket request must present this token — the web
# UI prompts for it once and remembers it. REQUIRED before exposing Octogent
# through a tunnel (see docs/remote-access.md). Use a long random value, e.g.
# run in PowerShell:  -join ((48..57)+(97..122) | Get-Random -Count 32 | % {[char]$_})
# No spaces around the = sign!
OCTOGENT_AUTH_TOKEN=
# Set to 1 ONLY when serving through a tunnel; leave unset for local use.
# Never enable this without OCTOGENT_AUTH_TOKEN also set.
# OCTOGENT_ALLOW_REMOTE_ACCESS=1

# The following bundled skills need NO API key:
#   - infographic-generator  (requires: cd /tmp && npm install playwright)
#   - gmail-triage           (requires: npm install -g @googleworkspace/cli && gws auth setup)
#   - linkedin-asset-analyzer (no external setup)
