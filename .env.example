# ── Anthropic (required) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (defaults shown)
DEFAULT_MODEL=claude-sonnet-4-6
RESEARCH_MODEL=claude-opus-4-7

# ── ElevenLabs TTS (optional) ────────────────────────────────────────────────
# Get your key at https://elevenlabs.io — free tier: 10,000 chars/mo.
# Once set, enable in Open WebUI by also setting AUDIO_TTS_ENGINE=elevenlabs
ELEVENLABS_API_KEY=

# Set to 'elevenlabs' to activate ElevenLabs in Open WebUI (needs key above)
# Leave blank to use browser built-in TTS (free, no key needed)
AUDIO_TTS_ENGINE=

# Optional: override the default voice (Rachel). Get IDs from elevenlabs.io/voices
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── Open WebUI ────────────────────────────────────────────────────────────────
# Change this to any random string before deploying
WEBUI_SECRET_KEY=jarvis-webui-secret-change-me

# ── Integrations ──────────────────────────────────────────────────────────────
LOCAL_FALCON_API_KEY=
BRAVE_SEARCH_API_KEY=

# ── Paths ─────────────────────────────────────────────────────────────────────
# Absolute path to your Obsidian vault root (optional)
OBSIDIAN_VAULT_PATH=

# ── System ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_RESEARCH_DEPTH=3
PARALLEL_CLIENTS=5
