# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (defaults shown)
DEFAULT_MODEL=claude-sonnet-4-6
RESEARCH_MODEL=claude-opus-4-7

# ── Paths ─────────────────────────────────────────────────────────────────────
# Absolute path to your Obsidian vault root
OBSIDIAN_VAULT_PATH=/Users/yourname/Documents/Obsidian/JarvisVault

# Override default locations (optional)
# CLIENTS_FILE=clients/clients.json
# METRICS_FILE=.jarvis/metrics.json
# SKILLS_DIR=skills

# ── Integrations ──────────────────────────────────────────────────────────────
LOCAL_FALCON_API_KEY=
BRAVE_SEARCH_API_KEY=

# ── TTS (ElevenLabs) ──────────────────────────────────────────────────────────
# Get your key at https://elevenlabs.io — free tier includes 10,000 chars/mo.
# If not set, Jarvis falls back to offline pyttsx3 TTS.
# Add --speak to any skill run or research command once configured.
ELEVENLABS_API_KEY=

# ── System ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_RESEARCH_DEPTH=3
PARALLEL_CLIENTS=5
