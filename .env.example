# Octogent + Skills — environment variables
#
# Copy this file to `.env` in your project root and fill in the keys you need.
# Octogent loads `.env` at startup and forwards every variable to the agents it
# spawns, so a single keystore powers all tentacles and bundled skills.
#
# Real environment variables always win — anything already set in your shell is
# never overwritten by this file.
#
# Check which keys are missing at any time with:
#   octogent skills status
#   octogent skills doctor

# video-performance-analyzer — Google Gemini (transcript + analysis)
# Also requires: pip install google-genai --break-system-packages
GEMINI_API_KEY=

# x-scanner — xAI Grok API (x_search)
XAI_API_KEY=

# twitter-reader — Jina.ai reader API
JINA_API_KEY=

# The following bundled skills need NO API key:
#   - infographic-generator  (requires: cd /tmp && npm install playwright)
#   - gmail-triage           (requires: npm install -g @googleworkspace/cli && gws auth setup)
#   - linkedin-asset-analyzer (no external setup)
