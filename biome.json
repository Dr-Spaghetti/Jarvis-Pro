{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "organizeImports": {
    "enabled": true
  },
  "overrides": [
    {
      "include": ["apps/web/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedGlobals": {
              "level": "error",
              "options": {
                "deniedGlobals": ["fetch"]
              }
            }
          }
        }
      }
    },
    {
      "include": [
        "apps/web/src/components/GlobalSearch.tsx",
        "apps/web/src/components/SurveillancePanel.tsx",
        "apps/web/src/components/TerminalPrimaryView.tsx",
        "apps/web/src/components/WorkflowsPrimaryView.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off",
            "noAutofocus": "off"
          }
        }
      }
    },
    {
      "include": ["apps/api/tests/**/*.test.ts", "apps/web/tests/**/*.test.tsx"],
      "linter": {
        "rules": {
          "performance": {
            "noDelete": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    }
  ],
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      "coverage",
      ".claude",
      ".octogent",
      "graphify-out",
      "worktrees",
      "skills-catalog"
    ]
  }
}
