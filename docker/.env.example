# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Generate all four with:
#   openssl rand -hex 32   (for JWT_SECRET, JWT_REFRESH_SECRET, CREDS_KEY)
#   openssl rand -hex 16   (for CREDS_IV — must be exactly 16 bytes / 32 hex chars)
JWT_SECRET=
JWT_REFRESH_SECRET=
CREDS_KEY=
CREDS_IV=

# ── Optional integrations ─────────────────────────────────────────────────────
LOCALFALCON_API_KEY=
TAVILY_API_KEY=

# ── LibreChat settings ────────────────────────────────────────────────────────
MEILI_MASTER_KEY=masterKey
ALLOW_REGISTRATION=false

# ── Notes ─────────────────────────────────────────────────────────────────────
# SECURITY: LibreChat v0.8.5 patches CVE-2026-22252 (MCP stdio RCE).
# Pin the image in docker-compose.yml to a numbered release tag.
# Update monthly and check https://github.com/danny-avila/LibreChat/releases.
#
# LOCAL FALCON: Use the Streamable HTTP endpoint in librechat.yaml (recommended
# for Windows) — no need to install @local-falcon/mcp via npx.
#
# JARVIS API: Start the OpenAI-compatible server before starting Docker:
#   python serve.py        # port 8000 — "models" endpoint for LibreChat
#   python mcp_http_server.py   # port 8765 — MCP tools endpoint
