# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# Generate with: openssl rand -hex 32 (must be exactly 32 chars)
CREDS_KEY=
# Generate with: openssl rand -hex 16 (must be exactly 16 chars)
CREDS_IV=

# ── Optional ──────────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=masterKey
ALLOW_REGISTRATION=false

# For the Jarvis MCP server (passed into the container)
OBSIDIAN_VAULT_PATH=
LOCAL_FALCON_API_KEY=
